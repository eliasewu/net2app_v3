// ===================== VOICE OTP API =====================
// Send Voice OTP
app.post('/api/voice-otp/send', auth, async (req, res) => {
  try {
    const { destination, language = 'en', otp_code, client_id } = req.body;
    const finalOtp = otp_code || Math.floor(100000 + Math.random() * 900000).toString();
    
    const result = await pool.query(
      `INSERT INTO voice_otp_logs (call_id, destination, otp_code, language, client_id, status, created_at)
       VALUES ($1, $2, $3, $4, $5, 'initiated', NOW())
       RETURNING *`,
      ['VOICE_' + Date.now() + '_' + Math.random().toString(36).substr(2, 4), 
       destination, finalOtp, language, client_id]
    );
    
    res.json({ 
      success: true, 
      data: result.rows[0],
      message: `OTP ${finalOtp} sent to ${destination}`
    });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// Get Voice OTP logs
app.get('/api/voice-otp/logs', auth, async (req, res) => {
  try {
    const { limit = 100, offset = 0 } = req.query;
    const result = await pool.query(
      'SELECT * FROM voice_otp_logs ORDER BY created_at DESC LIMIT $1 OFFSET $2',
      [limit, offset]
    );
    res.json({ success: true, data: result.rows });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// Verify OTP code
app.post('/api/voice-otp/verify', auth, async (req, res) => {
  try {
    const { call_id, otp_code } = req.body;
    
    const result = await pool.query(
      'SELECT * FROM voice_otp_logs WHERE call_id = $1 AND otp_code = $2',
      [call_id, otp_code]
    );
    
    if (result.rows.length > 0) {
      await pool.query(
        'UPDATE voice_otp_logs SET status = $1, completed_at = NOW() WHERE call_id = $2',
        ['verified', call_id]
      );
      res.json({ success: true, message: 'OTP verified successfully' });
    } else {
      res.status(400).json({ success: false, error: 'Invalid OTP' });
    }
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

