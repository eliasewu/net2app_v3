// ===================== SMS INBOX (MO) API =====================
// Receive incoming SMS (from external)
app.post('/api/sms/inbox/receive', async (req, res) => {
  try {
    const { from_number, to_number, message, client_id, smsc_reference } = req.body;
    
    const result = await pool.query(
      `INSERT INTO sms_inbox (message_id, from_number, to_number, message, client_id, smsc_reference, received_at, status)
       VALUES ($1, $2, $3, $4, $5, $6, NOW(), 'received')
       RETURNING *`,
      ['MO_' + Date.now() + '_' + Math.random().toString(36).substr(2, 4), 
       from_number, to_number, message, client_id, smsc_reference]
    );
    
    res.json({ success: true, data: result.rows[0] });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// Get SMS Inbox (MO messages)
app.get('/api/sms/inbox', auth, async (req, res) => {
  try {
    const { client_id, status, limit = 100, offset = 0 } = req.query;
    let query = 'SELECT * FROM sms_inbox WHERE 1=1';
    const params = [];
    let paramCount = 1;
    
    if (client_id) {
      params.push(client_id);
      query += ` AND client_id = $${paramCount++}`;
    }
    if (status) {
      params.push(status);
      query += ` AND status = $${paramCount++}`;
    }
    
    params.push(limit, offset);
    query += ` ORDER BY received_at DESC LIMIT $${paramCount++} OFFSET $${paramCount++}`;
    
    const result = await pool.query(query, params);
    res.json({ success: true, data: result.rows, total: result.rowCount });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

