// Create user
app.post('/api/users', auth, async (req, res) => {
  try {
    const { username, password, email, role, permissions, name } = req.body;
    const hashedPassword = await bcrypt.hash(password, 10);
    
    const result = await pool.query(
      `INSERT INTO users (username, password_hash, email, role, permissions, name, is_active, created_at)
       VALUES ($1, $2, $3, $4, $5, $6, true, NOW())
       RETURNING id, username, email, role, name, is_active`,
      [username, hashedPassword, email, role || 'agent', permissions || '{}', name]
    );
    res.json({ success: true, data: result.rows[0] });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// Update user
app.put('/api/users/:id', auth, async (req, res) => {
  try {
    const { email, role, permissions, name, is_active } = req.body;
    const result = await pool.query(
      `UPDATE users SET email = COALESCE($1, email), role = COALESCE($2, role),
       permissions = COALESCE($3, permissions), name = COALESCE($4, name),
       is_active = COALESCE($5, is_active), updated_at = NOW()
       WHERE id = $6 RETURNING id, username, email, role, name, is_active`,
      [email, role, permissions, name, is_active, req.params.id]
    );
    res.json({ success: true, data: result.rows[0] });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// Delete user
